{
  "name": "github_copilot_only",
  "description": "GitHub Copilot MCP server over streamable HTTP",
  "mcpServers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${env:GITHUB_MCP_PAT}"
      },
      "protocolVersion": "2025-11-25",
      "allowStateless": true
    }
  }
}
